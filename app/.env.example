# ── Server ───────────────────────────────────────────────────────────────────
# API server port — change if running multiple instances (e.g. PORT=3002)
# PORT=3001

# ── Seats.aero Partner API ────────────────────────────────────────────────────
# Powers the Award Search tab — live award availability across 30+ programs.
# Sign up at: https://seats.aero (paid partner API, $9.99/month)
SEATS_API_KEY=

# ── Sky Scrapper (Skyscanner) via RapidAPI ────────────────────────────────────
# Powers live business/premium economy cash price lookups.
# Free tier: 100 calls/month — sufficient for personal use.
# Sign up at: https://rapidapi.com → search "sky-scrapper" → subscribe (free tier)
RAPIDAPI_KEY=

# ── Travelpayouts ─────────────────────────────────────────────────────────────
# Powers economy cash price baseline lookups.
# Free API — sign up at: https://www.travelpayouts.com/developers/api
TRAVELPAYOUTS_TOKEN=
